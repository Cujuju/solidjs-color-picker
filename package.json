{
  "name": "cujuju-solidjs-color-picker",
  "version": "0.1.1",
  "description": "TradingView-style color picker for SolidJS — canvas-based HSV controls, palette grid, alpha support, EyeDropper API, zero dependencies.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "solid": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "sideEffects": false,
  "license": "MIT",
  "keywords": [
    "solidjs",
    "color-picker",
    "tradingview",
    "hsv",
    "canvas",
    "palette"
  ],
  "peerDependencies": {
    "solid-js": ">=1.7.0"
  },
  "devDependencies": {},
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "vite build"
  }
}
